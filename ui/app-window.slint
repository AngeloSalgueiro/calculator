import { Button, GridBox, LineEdit } from "std-widgets.slint";

component Calculator inherits Rectangle {
    callback send-carac(string);
    callback send-key(string);

    in-out property <string> input_value <=> input.text;
    in-out property <string> placeholder_value;
    in property <[string]> Calculator_buttons: [
        "7",
        "8",
        "9",
        "/",
        "4",
        "5",
        "6",
        "*",
        "1",
        "2",
        "3",
        "-",
        "0",
        "(",
        ")",
        "+"
    ];

    VerticalLayout {
        cross-axis-alignment: center;
        padding-top: 15px;
        spacing: 20px;

        init => {
            input.focus();
        }
        
        Rectangle {
            background: white;
            border-color: #c0c0c0;
            border-width: 1px;
            border-radius: 4px;

            height: 40px;
            width: parent.width - 25px;

            input := TextInput {
                vertical-alignment: center;
                x: 8px;
                color: black;
                width: parent.width - 16px;
                height: parent.height;
                font-size: 20px;

                key-pressed(event) => {
                    if event.text == "x" {
                        root.send-key("x")
                    } else {
                        root.send-key(event.text);
                    }
                    return reject;
                }

                accepted() => {
                    root.send-carac("=")
                }
            }

            Text {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;

                text: "0";
                font-size: 20px;
                color: #888;
                visible: input.text == "";
                vertical-alignment: center;
            }
        }

        GridLayout {
            width: parent.width - 50px;
            spacing: 5px;

            for button[i] in Calculator_buttons: Button {
                width: 50px;
                height: 35px;
                text: button;
                row: floor(i / 4);
                col: mod(i, 4);

                clicked => {
                    root.send-carac(button)
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "C";
                row: 0;
                col: 5;

                clicked => {
                    root.send-carac("C")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "<-";
                row: 1;
                col: 5;

                clicked => {
                    root.send-carac("<-")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: ".";
                row: 2;
                col: 5;

                clicked => {
                    root.send-carac(".")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "=";
                row: 3;
                col: 5;

                clicked => {
                    root.send-carac("=")
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    icon: @image-url("icons/design.svg");
    title: @tr("Calculator");

    callback send-carac(string);
    callback send-key(string);

    in-out property <string> input_value <=> calc.input_value;
    in-out property <string> placeholder_value <=> calc.placeholder_value;

    width: 326px;
    height: 326px;

    calc := Calculator {
        send-carac(value) => { root.send-carac(value) }
        send-key(value) => { root.send-key(value) }
    }
}
