import { Button, GridBox, LineEdit } from "std-widgets.slint";

component Calculator inherits Rectangle {
    callback send-carac(string);
    callback send-key(string);

    in-out property <string> input_value <=> input.text;
    in-out property <string> placeholder_value;
    in property <[string]> Calculator_buttons: [
        "7",
        "8",
        "9",
        "/",
        "4",
        "5",
        "6",
        "*",
        "1",
        "2",
        "3",
        "-",
        "0",
        "(",
        ")",
        "+"
    ];

    VerticalLayout {
        cross-axis-alignment: center;
        padding-top: 15px;
        spacing: 20px;

        init => {
            input.focus();
        }

        input := LineEdit {
            width: parent.width - 50px;
            height: 40px;
            font-size: 20px;
            placeholder-text: root.placeholder_value != "" ? root.placeholder_value : "0";

            key-pressed(event) => {
                if event.text == "x" {
                    root.send-key("x")
                } else {
                    root.send-key(event.text);
                }
                return reject;
            }

            accepted(text) => {
                root.send-carac("=")
            }
        }

        GridLayout {
            width: parent.width - 50px;
            spacing: 5px;

            for button[i] in Calculator_buttons: Button {
                width: 50px;
                height: 35px;
                text: button;
                row: floor(i / 4);
                col: mod(i, 4);

                clicked => {
                    root.send-carac(button)
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "C";
                row: 0;
                col: 5;

                clicked => {
                    root.send-carac("C")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "<-";
                row: 1;
                col: 5;

                clicked => {
                    root.send-carac("<-")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: ".";
                row: 2;
                col: 5;

                clicked => {
                    root.send-carac(".")
                }
            }

            Button {
                width: 50px;
                height: 35px;
                text: "=";
                row: 3;
                col: 5;

                clicked => {
                    root.send-carac("=")
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    icon: @image-url("icons/design.svg");
    title: @tr("Calculator");

    callback send-carac(string);
    callback send-key(string);

    in-out property <string> input_value <=> calc.input_value;
    in-out property <string> placeholder_value <=> calc.placeholder_value;

    width: 326px;
    height: 326px;

    calc := Calculator {
        send-carac(value) => { root.send-carac(value) }
        send-key(value) => { root.send-key(value) }
    }
}
